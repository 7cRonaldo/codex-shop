# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.nyc_output/

# build output
/dist/
*.tsbuildinfo

# misc
.DS_Store
Thumbs.db
Desktop.ini
*.pem
*.local
*.tmp
*.swp

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# environment files (sample files may be committed)
.env*
!.env.example
!.env.*.example

# editors
/.idea/
/.vscode/*
!/.vscode/extensions.json

# retired hosting and local tool files
/.wrangler/
/.openai/
/.npm-cache/
/.dev-*.log
.vite/
vite.config.*.timestamp-*
